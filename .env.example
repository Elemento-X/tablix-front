# Upstash Redis (required)
# Create a database at https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Node environment (managed by Next.js — do not set manually)
# NODE_ENV=development

# Sentry (error tracking)
# Create a project at https://sentry.io — DSN is public (safe for client-side)
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@o0.ingest.sentry.io/0
SENTRY_AUTH_TOKEN=sntrys_your-auth-token
SENTRY_ORG=your-org
SENTRY_PROJECT=tablix-front

# Health check deep endpoint secret
HEALTH_SECRET=your-random-secret-here

NEXT_PUBLIC_POSTHOG_KEY=phc_your-project-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com